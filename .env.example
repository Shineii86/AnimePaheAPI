# ======= • ======= • ======= • ======= • =======• =======
# AnimePaheAPI — Environment Configuration
# ======= • ======= • ======= • ======= • =======• =======

# Server port
PORT=3000

# Base URL for animepahe.ch (change if domain changes)
BASE_URL=https://animepahe.ch

# iframe CDN base URL for streaming (kwik.cx or kwik.si)
IFRAME_BASE_URL=kwik.cx

# Browser user agent (for anti-bot bypass)
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36

# Manual cookies (optional — auto-extracted if not set)
# Format: "cookie1=value1; cookie2=value2"
COOKIES=

# Proxy configuration (optional)
USE_PROXY=false
PROXIES=

# CORS configuration (optional, defaults to *)
ALLOWED_ORIGINS=*

# Chrome headless mode (true/false, default: auto-detect)
CHROME_HEADLESS=
